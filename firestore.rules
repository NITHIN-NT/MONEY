rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly lock down the root so nothing can be read/written by default
    match /{document=**} {
      allow read, write: if false;
    }

    // CRITICAL: Only allow the logged-in user to access their specific vault document!
    // No other user can ever see or modify these financial records.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
